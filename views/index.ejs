<!DOCTYPE html>
<html lang="Pt-Br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/style.css">
    <title>Encurtador de URLs</title>
</head>
<body>
    <div class="container">
        <h1>Encurtador de URL</h1>
   <!-- Exibe mensagem de erro, se houver -->
        <% if (typeof error !== 'undefined' && error) { %>
        <p style="color: #ff4d4d; font-weight: bold; margin-bottom: 20px;">
            <%= error %>
        </p>
      <% } %>
         <!-- Formulário de encurtamento -->
    <form action="/shorten" method="POST">
         <input type="url" name="url" placeholder="Cole seu link aqui" required>
         <input type="text" name="customUrl" placeholder="URL personalizada (opcional)" 
         pattern="[a-zA-Z0-9\-_]+"
         pattern="[a-zA-Z0-9\-_]+" 
         title="Não use espaços ou caracteres especiais. Use apenas letras, números, hífens ou underline."
         style="margin-top: 10px;">
        <br>
        <button type="submit">Encurtar</button>
    </form>
     <!-- Exibe o link encurtado, se gerado -->
        <% if (typeof linkGerado !== 'undefined' && linkGerado) { %>
            <div class="bloco-resultado">
                <a href="<%= linkGerado %>" target="_blank" class="success-link" id="url">
                    <%= linkGerado.replace('https://', '') %>
                </a>   <!-- Remove o "https://" para deixar o link mais limpo -->
                <br>
                <button type="button" onclick="aoCopiar()" id="btnCopiar" style="margin-top: 15px; padding: 10px 30px; font-size: 1rem;">
                    Copiar Link
                </button>
            </div>
        <% } %>
    </div>

    <script>  // Função para copiar o link encurtado para a área de transferência
        function aoCopiar() {
        
            const endereco = document.getElementById('url').href;
            const botao = document.getElementById('btnCopiar');

            navigator.clipboard.writeText(endereco).then(() => {
                const textoOriginal = botao.innerText;
                
            
                botao.innerText = "Copiado!";
                botao.style.background = "#28a745"; 
                
        
                setTimeout(() => {
                    botao.innerText = textoOriginal;
                    botao.style.background = ""; 
                }, 2000);
            }).catch(err => {
                console.error("Erro ao copiar: ", err);
            });
        }
    </script>
</body>
</html>
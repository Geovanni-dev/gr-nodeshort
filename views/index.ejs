<!DOCTYPE html>
<html lang="Pt-Br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/style.css">
    <title>Encurtador de URLs</title>
</head>
<body>

    <!-- Título das tecnologias -->
<h2 class="tech-title">Tecnologias Utilizadas:</h2>

<!-- Badges das tecnologias COM LINKS -->
<div class="tech-badges">
    <a href="https://nodejs.org/" target="_blank" rel="noopener noreferrer">
        <img src="https://img.shields.io/badge/Node.js-339933?style=for-the-badge&logo=nodedotjs&logoColor=white" alt="Node.js" />
    </a>
    <a href="https://expressjs.com/" target="_blank" rel="noopener noreferrer">
        <img src="https://img.shields.io/badge/Express.js-000000?style=for-the-badge&logo=express&logoColor=white" alt="Express.js" />
    </a>
    <a href="https://www.mongodb.com/" target="_blank" rel="noopener noreferrer">
        <img src="https://img.shields.io/badge/MongoDB-4EA94B?style=for-the-badge&logo=mongodb&logoColor=white" alt="MongoDB" />
    </a>
    <a href="https://ejs.co/" target="_blank" rel="noopener noreferrer">
        <img src="https://img.shields.io/badge/EJS-8B5A2B?style=for-the-badge&logo=ejs&logoColor=white" alt="EJS" />
    </a>
    <a href="https://zod.dev/" target="_blank" rel="noopener noreferrer">
        <img src="https://img.shields.io/badge/Zod-3E6B9E?style=for-the-badge&logo=zod&logoColor=white" alt="Zod" />
    </a>
</div>

<div class="container">
    <h1>Encurtador de URL</h1>
    
    <!-- Exibe mensagem de erro, se houver -->
    <% if (typeof error !== 'undefined' && error) { %>
    <p style="color: #ff4d4d; font-weight: bold; margin-bottom: 20px;">
        <%= error %>
    </p>
    <% } %>
    
    <!-- Formulário de encurtamento -->
    <form action="/shorten" method="POST">
        <input type="url" name="url" placeholder="Cole seu link aqui" required>
        <input type="text" name="customUrl" placeholder="URL personalizada (opcional)" 
               pattern="[a-zA-Z0-9\-_]+" 
               title="Não use espaços ou caracteres especiais. Use apenas letras, números, hífens ou underline."
               style="margin-top: 10px;">
        <br>
        <button type="submit">Encurtar</button>
    </form>
    
    <!-- Exibe o link encurtado, se gerado -->
    <% if (typeof linkGerado !== 'undefined' && linkGerado) { %>
        <div class="bloco-resultado">
            <a href="<%= linkGerado %>" target="_blank" class="success-link" id="url">
                <%= linkGerado.replace('https://', '') %>
            </a>
            <br>
            <button type="button" onclick="aoCopiar()" id="btnCopiar">
                Copiar Link
            </button>
        </div>
    <% } %>
</div>

<!-- COPYRIGHT -->
<div class="copyright">
    © 2026 Geovani Rodrigues
</div>

<!--link do script--->  
<script src="/script.js"></script>

</body>
</html>